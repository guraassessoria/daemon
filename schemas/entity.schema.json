{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://daemon-tools.local/schemas/entity.schema.json",
  "title": "Daemon Tools Entity",
  "type": "object",
  "required": ["id", "name", "category", "source", "entries"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": ["core_rule", "attribute_skill", "combat", "character_option", "kit_class", "race_lineage", "power_magic", "ritual_spell", "item_equipment", "creature_npc", "setting_lore", "adventure", "table_generator", "source"]
    },
    "source": {
      "type": "string"
    },
    "page": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "extractionMethod": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
